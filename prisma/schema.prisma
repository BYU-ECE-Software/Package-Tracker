generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Role {
  STUDENT
  SECRETARY
}

enum NotificationType {
  ARRIVAL
  FOLLOW_UP
}

// ─── MODELS ───────────────────────────────────────────────────────────────────

model User {
  id       String @id @default(cuid())
  netId    String @unique
  fullName String
  email    String
  role     Role   @default(STUDENT)

  // Relations
  packagesReceived Package[] @relation("PackageRecipient")
  packagesCheckedIn Package[] @relation("CheckedInBy")
  packagesCheckedOut Package[] @relation("CheckedOutBy")
  packagesPickedUp Package[] @relation("PickedUpBy")
  
  // Notifications sent to this user
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([netId])
  @@index([role])
}

model Package {
  id        String   @id @default(cuid())
  
  // Recipient
  recipientId String
  recipient   User   @relation("PackageRecipient", fields: [recipientId], references: [id])
  
  // Dropdowns
  carrierId String?
  carrier   Carrier? @relation(fields: [carrierId], references: [id])
  
  senderId  String?
  sender    Sender?  @relation(fields: [senderId], references: [id])

  notes     String?  @db.Text
  
  // Check-in
  dateArrived   DateTime
  checkedInById String
  checkedInBy   User     @relation("CheckedInBy", fields: [checkedInById], references: [id])
  
  // Check-out
  datePickedUp     DateTime?
  checkedOutById   String?
  checkedOutBy     User?     @relation("CheckedOutBy", fields: [checkedOutById], references: [id])
  
  // Deliver Info
  deliveredToOffice Boolean  @default(false)
  pickedUpByUserId String?
  pickedUpBy       User?     @relation("PickedUpBy", fields: [pickedUpByUserId], references: [id])

  // Notification tracking
  notifications Notification[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([recipientId])
  @@index([carrierId])
  @@index([senderId])
  @@index([dateArrived])
  @@index([datePickedUp])
}

model Notification {
  id          String   @id @default(cuid())
  
  packageId   String
  package     Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  
  recipientId String
  recipient   User     @relation(fields: [recipientId], references: [id])
  
  type        NotificationType
  subject     String
  body        String   @db.Text

  sentAt      DateTime @default(now())

  @@index([recipientId])
  @@index([packageId])
}

model Carrier {
  id       String    @id @default(cuid())
  name     String    @unique
  hidden   Boolean   @default(false)
  order    Int       @default(0)
  packages Package[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hidden, order])
}

model Sender {
  id       String    @id @default(cuid())
  name     String    @unique
  hidden   Boolean   @default(false)
  order    Int       @default(0)
  packages Package[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hidden, order])
}
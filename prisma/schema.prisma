generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Role {
  STUDENT
  SECRETARY
  ADMIN
}

enum PackageStatus {
  ACTIVE           // Default - package is waiting for pickup
  PICKED_UP        // Normal pickup completed
  DELIVERED        // Delivered to office
  LOST             // Package cannot be found
  RETURNED         // Sent back to sender
  DAMAGED          // Package arrived damaged
  HELD             // On hold for some reason
}

// ─── MODELS ───────────────────────────────────────────────────────────────────

model User {
  id       String @id @default(cuid())
  netId    String @unique
  fullName String
  email    String?
  role     Role   @default(STUDENT)

  // Packages where this user is the recipient
  packagesReceived Package[] @relation("PackageRecipient")
  
  // Packages this user checked in (as secretary)
  packagesCheckedIn Package[] @relation("CheckedInBy")
  
  // Packages this user checked out (as secretary)
  packagesCheckedOut Package[] @relation("CheckedOutBy")
  
  // Packages this user physically picked up (could be recipient or someone else)
  packagesPickedUp Package[] @relation("PickedUpBy")
  
  // Notifications sent to this user
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([netId])
  @@index([role])
}

model Package {
  id        String   @id @default(cuid())
  
  // Recipient (who the package is for)
  recipientId String
  recipient   User   @relation("PackageRecipient", fields: [recipientId], references: [id])
  
  // Dropdown selections
  carrierId String?
  carrier   Carrier? @relation(fields: [carrierId], references: [id])
  
  senderId  String?
  sender    Sender?  @relation(fields: [senderId], references: [id])
  
  // Check-in info (when package arrived)
  dateArrived   DateTime
  checkedInById String?
  checkedInBy   User?    @relation("CheckedInBy", fields: [checkedInById], references: [id])
  
  // Check-out info (when package left)
  datePickedUp     DateTime?
  checkedOutById   String?
  checkedOutBy     User?     @relation("CheckedOutBy", fields: [checkedOutById], references: [id])
  
  // NEW: Who actually picked it up (might differ from recipient)
  pickedUpByUserId String?
  pickedUpBy       User?     @relation("PickedUpBy", fields: [pickedUpByUserId], references: [id])
  
  deliveredToOffice Boolean  @default(false)
  
  // NEW: Status for edge cases
  status PackageStatus @default(ACTIVE)
  
  // Notification tracking
  notificationSent Boolean @default(false)
  
  // NEW: Relation to notification history
  notifications Notification[]
  
  notes     String?  @db.Text
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([recipientId])
  @@index([carrierId])
  @@index([senderId])
  @@index([dateArrived])
  @@index([datePickedUp])
  @@index([status])
}

// NEW MODEL: Email notification history
model Notification {
  id          String   @id @default(cuid())
  
  packageId   String
  package     Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  
  recipientId String
  recipient   User     @relation(fields: [recipientId], references: [id])
  
  subject     String
  body        String   @db.Text
  
  sentAt      DateTime @default(now())
  readAt      DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([recipientId, readAt])
  @@index([packageId])
}

model Carrier {
  id       String    @id @default(cuid())
  name     String    @unique
  hidden   Boolean   @default(false)
  order    Int       @default(0)
  packages Package[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hidden, order])
}

model Sender {
  id       String    @id @default(cuid())
  name     String    @unique
  hidden   Boolean   @default(false)
  order    Int       @default(0)
  packages Package[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hidden, order])
}
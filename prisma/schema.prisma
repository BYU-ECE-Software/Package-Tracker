// ============================================
// 1. PRISMA SCHEMA (prisma/schema.prisma)
// ============================================


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  SECRETARY
  ADMIN
}

model User {
  id                    String    @id @default(cuid())
  netId                 String    @unique
  email                 String    @unique
  fullName              String
  role                  UserRole  @default(STUDENT)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  
  // Relations
  packages              Package[] @relation("StudentPackages")
  checkedInPackages     Package[] @relation("CheckedInBy")
  checkedOutPackages    Package[] @relation("CheckedOutBy")
  
  @@index([netId])
  @@index([email])
}

model Carrier {
  id       String    @id @default(cuid())
  name     String    @unique
  isActive Boolean   @default(true)
  packages Package[]
}

model Sender {
  id       String    @id @default(cuid())
  name     String    @unique
  isActive Boolean   @default(true)
  packages Package[]
}

model Package {
  id                    String         @id @default(cuid())
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  // Dropdown Menus
  carrierId   String?
  carrier     Carrier? @relation(fields: [carrierId], references: [id], onDelete: SetNull)

  senderId    String?
  sender      Sender?  @relation(fields: [senderId], references: [id], onDelete: SetNull)

  // Dates
  dateArrived           DateTime        @default(now())
  datePickedUp          DateTime?

  // User Relations
  studentId             String         // Recipient
  student               User           @relation("StudentPackages", fields: [studentId], references: [id], onDelete: Cascade)
  
  checkedInById         String?        // Secretary logging package
  checkedInBy           User?          @relation("CheckedInBy", fields: [checkedInById], references: [id], onDelete: SetNull)
  
  checkedOutById        String?        // Secretary updating delivered package
  checkedOutBy          User?          @relation("CheckedOutBy", fields: [checkedOutById], references: [id], onDelete: SetNull)
  
  deliveredToOffice     Boolean        @default(false)

  // Additional fields
  notes                 String?        @db.Text
  notificationSent      Boolean        @default(false)
  
  @@index([studentId])
  @@index([carrierId])
  @@index([senderId])
  @@index([dateArrived])
}
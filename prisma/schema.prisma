generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Role {
  STUDENT
  SECRETARY
}

enum NotificationType {
  ARRIVAL
  FOLLOW_UP
}

enum Status {
  REQUESTED
  PURCHASED
  COMPLETED
  RETURNED
  CANCELLED
}

// ─── MODELS ───────────────────────────────────────────────────────────────────

model User {
  id       String @id @default(cuid())
  netId    String @unique
  fullName String
  email    String
  role     Role   @default(STUDENT)

  // Package relations
  packagesReceived Package[] @relation("PackageRecipient")
  packagesCheckedIn Package[] @relation("CheckedInBy")
  packagesCheckedOut Package[] @relation("CheckedOutBy")
  packagesPickedUp Package[] @relation("PickedUpBy")
  notifications Notification[]

  // Order relations
  ordersRequested  Order[] @relation("OrderRequester")
  ordersPurchased  Order[] @relation("OrderPurchaser")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([netId])
  @@index([role])
}

model Package {
  id        String   @id @default(cuid())
  
  // Recipient
  recipientId String
  recipient   User   @relation("PackageRecipient", fields: [recipientId], references: [id])
  
  // Dropdowns
  carrierId String?
  carrier   Carrier? @relation(fields: [carrierId], references: [id])
  
  vendorId  String?
  vendor    Vendor?  @relation(fields: [vendorId], references: [id])
  notes     String?  @db.Text
  
  // Check-in
  dateArrived   DateTime
  checkedInById String
  checkedInBy   User     @relation("CheckedInBy", fields: [checkedInById], references: [id])
  
  // Check-out
  datePickedUp     DateTime?
  checkedOutById   String?
  checkedOutBy     User?     @relation("CheckedOutBy", fields: [checkedOutById], references: [id])
  
  // Deliver Info
  deliveredToOffice Boolean  @default(false)
  pickedUpByUserId String?
  pickedUpBy       User?     @relation("PickedUpBy", fields: [pickedUpByUserId], references: [id])

  // Notification tracking
  notifications Notification[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([recipientId])
  @@index([carrierId])
  @@index([vendorId])
  @@index([dateArrived])
  @@index([datePickedUp])
  @@index([createdAt])
}

model Notification {
  id          String   @id @default(cuid())
  
  packageId   String
  package     Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  
  recipientId String
  recipient   User     @relation(fields: [recipientId], references: [id])
  
  type        NotificationType
  subject     String
  body        String   @db.Text

  sentAt      DateTime @default(now())

  @@index([recipientId])
  @@index([packageId])
}

model Carrier {
  id       String    @id @default(cuid())
  name     String    @unique
  hidden   Boolean   @default(false)
  order    Int       @default(0)
  packages Package[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hidden, order])
}

model Vendor {
  id       String    @id @default(cuid())
  name     String    @unique
  hidden   Boolean   @default(false)
  order    Int       @default(0)
  packages Package[]
  orders   Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([hidden, order])
}

model Order {
  id                 String   @id @default(cuid())

  // Request info
  requestDate        DateTime
  status             Status @default(REQUESTED)
  shippingPreference String?
  purpose            String
  workTag            String
  cartLink           String?
  comment            String?

  // Costs
  tax                Float?
  total              Float?

  // Requester (student)
  userId             String
  user               User     @relation("OrderRequester", fields: [userId], references: [id])

  // Vendor
  vendorId           String
  vendor             Vendor @relation(fields: [vendorId], references: [id])

  // Professor association
  professorId        String
  professor          Professor @relation(fields: [professorId], references: [id])

  // Categorization
  spendCategoryId    String
  spendCategory      SpendCategory @relation(fields: [spendCategoryId], references: [id])

  lineMemoOptionId   Int?
  lineMemoOption     LineMemoOption? @relation(fields: [lineMemoOptionId], references: [id])

  // Purchase info (filled by secretary)
  purchasedById      String?
  purchasedBy        User?     @relation("OrderPurchaser", fields: [purchasedById], references: [id])
  creditCard         Boolean?
  purchaseDate       DateTime?
  receipt            String[]  @default([])
  adminComment       String?

  // Items
  items              Item[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([purchasedById])
  @@index([professorId])
  @@index([spendCategoryId])
  @@index([requestDate])
  @@index([createdAt])
}

model Item {
  id       String     @id @default(cuid())
  name     String
  quantity Int
  status   Status @default(REQUESTED)
  link     String?
  file     String?

  orderId  String
  order    Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([status])
}

model SpendCategory {
  id                String  @id @default(cuid())
  code              String  @unique
  description       String
  visibleToStudents Boolean @default(true)
  orders            Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
}

model LineMemoOption {
  id          Int      @id
  description String
  orders      Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Professor {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  title     String?
  email     String?
  orders    Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lastName])
}
